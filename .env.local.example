# Built-in model configuration (copy to .env.local and fill in your values)
# These are injected at build time via electron-vite define.
# The built-in model is used when users have not configured their own API key,
# or when BUILT_IN_MODEL_ENABLED=true overrides user config.

BUILT_IN_PROVIDER=anthropic
BUILT_IN_MODEL=claude-3-5-haiku-20241022
BUILT_IN_API_KEY=sk-ant-xxxxxxxx
BUILT_IN_BASE_URL=
BUILT_IN_MAX_TOKENS=4096
# Set to "true" to always use the built-in model (hide model settings from users)
BUILT_IN_FORCE=false
