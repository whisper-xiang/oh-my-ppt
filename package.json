{
  "name": "oh-my-ppt",
  "version": "2.0.10",
  "description": "Oh My PPT - Local-first AI presentation workbench",
  "main": "./out/main/index.js",
  "author": "arcsin1",
  "homepage": "https://github.com/arcsin1/oh-my-ppt",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "electron:generate-icons": "npx @arcsin1/electron-icon-builder --input=./resources/icon.png --output=build --flatten"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.6",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@joplin/turndown-plugin-gfm": "^1.0.64",
    "@langchain/anthropic": "^1.3.29",
    "@langchain/core": "^1.1.46",
    "@langchain/langgraph": "^1.3.0",
    "@langchain/openai": "^1.4.5",
    "@libsql/client": "^0.14.0",
    "@node-rs/jieba": "^2.0.1",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.1",
    "@radix-ui/react-scroll-area": "^1.2.2",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-toast": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-virtual": "^3.11.2",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.20",
    "deepagents": "^1.10.2",
    "drizzle-orm": "^0.44.5",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.3.9",
    "fflate": "^0.8.2",
    "fonteditor-core": "^2.6.3",
    "isomorphic-git": "^1.37.6",
    "katex": "^0.16.45",
    "lucide-react": "^0.574.0",
    "mammoth": "^1.12.0",
    "nanoid": "^5.1.9",
    "pdf-lib": "^1.17.1",
    "pptxtojson": "^2.0.2",
    "react-colorful": "^5.7.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.1.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.0.1",
    "tiktoken": "^1.0.18",
    "turndown": "^7.2.4",
    "woff2-encoder": "^2.0.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.31.4",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "happy-dom": "^20.9.0",
    "postcss": "^8.4.49",
    "prettier": "^3.7.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vitest": "^4.1.6"
  },
  "pnpm": {
    "supportedArchitectures": {
      "os": [
        "current",
        "darwin",
        "win32"
      ],
      "cpu": [
        "current",
        "arm64",
        "x64"
      ]
    },
    "onlyBuiltDependencies": [
      "electron",
      "electron-winstaller",
      "esbuild",
      "protobufjs"
    ],
    "overrides": {
      "@langchain/core": "^1.1.46",
      "@langchain/langgraph": "^1.3.0"
    }
  }
}
